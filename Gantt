  .li { display: flex; align-items: center; gap: 4px; }
  .ld { width: 9px; height: 9px; border-radius: 2px; flex-shrink: 0; }
  .gw { overflow-x: auto; border: 0.5px solid var(--border); border-radius: var(--radius-lg); }
  table { width: 100%; min-width: 860px; border-collapse: collapse; }
  thead th { font-size: 10px; font-weight: 500; color: var(--text2); background: var(--bg2); position: sticky; top: 0; z-index: 2; padding: 0; border-bottom: 0.5px solid var(--border); }
  th.lc { text-align: left; padding: 7px 10px; min-width: 200px; position: sticky; left: 0; z-index: 3; }
  .sr td { padding: 4px 10px 3px; font-size: 10px; font-weight: 500; color: var(--text2); text-transform: uppercase; letter-spacing: 0.06em; background: var(--bg3); border-bottom: 0.5px solid var(--border); }
  .tr td { padding: 1px 4px; border-bottom: 0.5px solid var(--border); vertical-align: middle; }
  .tr:hover { background: var(--bg2); }
  .nc { font-size: 11px; color: var(--text); padding-left: 10px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px; position: sticky; left: 0; background: var(--bg); z-index: 1; }
  .tr:hover .nc { background: var(--bg2); }
  .bc { position: relative; height: 24px; min-width: 600px; }
  .bar { position: absolute; height: 13px; top: 5px; border-radius: 3px; cursor: pointer; transition: filter 0.1s; }
  .bar:hover { filter: brightness(1.12); }
  .dot { position: absolute; width: 12px; height: 12px; border-radius: 50%; top: 6px; transform: translateX(-50%); cursor: pointer; border: 2px solid var(--bg); }
  .tl { position: absolute; top: 0; bottom: 0; width: 1.5px; background: #E24B4A; pointer-events: none; z-index: 5; }
  .tlb { position: absolute; top: 1px; font-size: 9px; color: #E24B4A; transform: translateX(-50%); white-space: nowrap; font-weight: 500; }
  .tip { position: fixed; background: var(--bg); border: 0.5px solid var(--border2); border-radius: var(--radius); padding: 7px 11px; font-size: 12px; pointer-events: none; z-index: 9999; max-width: 260px; display: none; color: var(--text); box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
