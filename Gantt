function doff(d) { return (new Date(d) - S) / 864e5; }
function pct(x) { return Math.min(100, Math.max(0, x / TD * 100)); }
function fmt(d) { return d ? new Date(d).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'2-digit'}) : ''; }
function meta(sec) { return SM[sec] || {f:'other', c:'#888780', l:sec}; }
function vis(t) {
  if (filt === 'all') return true;
  if (filt === 'ms') return t.ms;
  return meta(t.s).f === filt;
}
 
function buildMonths() {
  const r = []; const c = new Date(S);
  while (c < E) {
    const lbl = c.toLocaleDateString('en-US', {month:'short', year:'2-digit'});
    const p0 = pct(doff(c.toISOString().slice(0,10)));
    const nx = new Date(c); nx.setMonth(nx.getMonth() + 1);
    r.push({lbl, p0, w: pct(doff(nx.toISOString().slice(0,10))) - p0});
    c.setMonth(c.getMonth() + 1);
  }
  return r;
}
 
