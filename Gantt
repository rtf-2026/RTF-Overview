  let html = '';
  ORDER.forEach(sec => {
    const tasks = T.filter(t => t.s === sec && vis(t));
    if (!tasks.length) return;
    const m = meta(sec);
    html += `<tr class="sr"><td colspan="2" style="border-left:3px solid ${m.c}">${m.l}</td></tr>`;
    tasks.forEach(t => {
      const sp = pct(doff(t.st));
      const ep = pct(doff(t.en || t.st));
      const wp = Math.max(0.4, ep - sp);
      const isPast = new Date(t.en || t.st) < TODAY;
      const isNow = new Date(t.st) <= TODAY && new Date(t.en || t.st) >= TODAY;
      const op = isPast ? '0.45' : '0.9';
      const nn = t.n.replace(/'/g, "\\'");
      const el = t.ms
        ? `<div class="dot" style="left:${sp.toFixed(2)}%;background:${m.c};opacity:${op}" onmouseenter="showTip(event,'${nn}','${t.st}','',true,'${m.l}')" onmouseleave="hideTip()"></div>`
        : `<div class="bar" style="left:${sp.toFixed(2)}%;width:${wp.toFixed(2)}%;background:${m.c};opacity:${op};${isNow ? 'outline:1.5px solid '+m.c+';outline-offset:1px' : ''}" onmouseenter="showTip(event,'${nn}','${t.st}','${t.en}',false,'${m.l}')" onmouseleave="hideTip()"></div>`;
      html += `<tr class="tr">
        <td class="nc" title="${t.n}">${t.ms ? `<i class="ti ti-diamond" style="font-size:10px;color:${m.c};margin-right:2px;vertical-align:1px"></i>` : ''}${t.n}</td>
        <td class="bc"><div style="position:relative;height:100%;width:100%">${el}<div class="tl" style="left:${tp.toFixed(2)}%"></div></div></td>
      </tr>`;
    });
  });
 
  document.getElementById('gb').innerHTML = html;
  document.getElementById('sc').textContent = T.filter(vis).length;
  renderMetrics();
}
 
function showTip(e, n, s, en, ms, ph) {
  const tip = document.getElementById('tip');
  tip.innerHTML = `<strong>${n}</strong><div class="tph">${ph}</div><div class="tdt">${ms ? '◆ Milestone · ' : ''}${fmt(s)}${en && en !== s ? ' → ' + fmt(en) : ''}</div>`;
  tip.style.display = 'block';
  tip.style.left = (e.clientX + 14) + 'px';
  tip.style.top = (e.clientY - 10) + 'px';
}
function hideTip() { document.getElementById('tip').style.display = 'none'; }
 
document.querySelectorAll('.fb').forEach(b => b.addEventListener('click', function() {
  filt = this.dataset.f;
  document.querySelectorAll('.fb').forEach(x => x.classList.remove('on'));
  this.classList.add('on');
  render();
}));
 
render();
</script>
</body>
