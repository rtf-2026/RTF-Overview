  .metrics { display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); gap: 8px; margin-bottom: 1rem; }
  .mc { background: var(--bg2); border-radius: var(--radius); padding: 9px 12px; }
  .mc .v { font-size: 20px; font-weight: 500; color: var(--text); line-height: 1.2; }
  .mc .l { font-size: 11px; color: var(--text2); margin-top: 2px; }
  .ctrls { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 0.75rem; align-items: center; }
